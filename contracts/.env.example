# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Required for Sepolia deployment ──────────────────────────────────────────
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# OR: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ── Required for Base Sepolia deployment ─────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Optional: contract verification on Etherscan / BaseScan ──────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ── Dynamic Price Keeper (scripts/priceKeeper.ts) ────────────────────────────
# Which chain to update oracle on: "sepolia" | "base-sepolia"
KEEPER_CHAIN=base-sepolia
# Private key for the keeper bot (must be oracle owner). Falls back to PRIVATE_KEY.
KEEPER_PRIVATE_KEY=0xYOUR_KEEPER_PRIVATE_KEY
# Override oracle contract address (auto-detected from KEEPER_CHAIN if omitted)
# ORACLE_ADDRESS=0x...

# ── Anvil local (already hardcoded in deploy-anvil.sh) ────────────────────────
# ANVIL_RPC_URL=http://localhost:8545
# ANVIL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
