# ─────────────────────────────────────────────────────────────────────────────
# PepeLab Agent — 環境變數範例（Phase 4：全程 Base Sepolia 同鏈）
# 複製成 .env 後填入實際值：  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── 鏈上讀取（Base Sepolia, chainId 84532）──────────────────────────────────
# 合約部署在 Base Sepolia；位址由 frontend/src/contracts/addresses.ts 讀取，
# 此處只需提供一個 Base Sepolia RPC。可用 Alchemy / 官方 / 公共節點。
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# （選用）回退到舊的 Ethereum Sepolia 部署：設 AGENT_CHAIN_ID=11155111 + 此 RPC。
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# AGENT_CHAIN_ID=84532

# ── x402 付費結算（Base Sepolia — 官方 USDC）─────────────────────────────────
# x402-hono 以 "$價格" + network 自動解析成該網路的官方 USDC：Base Sepolia 上即
# Circle 官方測試 USDC（6-dec, EIP-3009 transferWithAuthorization）。
X402_NETWORK=base-sepolia
# facilitator 負責驗證 + 上鏈結算。可用 x402.org 測試 facilitator 或 CDP。
X402_FACILITATOR_URL=https://x402.org/facilitator

# 收款地址 payTo。**Option 1：設為 treasury EOA（= 下方 FEE_SETTLEMENT 帳戶的地址）。**
# agent 付的官方 USDC 會進這個 EOA，再由 settlement 走 70/20/10 真分潤。
# （不要設成 MockUSDC 版 FeeRouter——它綁 18-dec MockUSDC，收到官方 USDC 會卡死。）
# 預填 = 部署/treasury 帳戶（需持少量 ETH 跑 routeExternalRevenue）。
PAY_TO=0xE80A81360608C1342e66743F70a00f75d792Eb93

# ── x402 收入「真上鏈分潤」結算（Option 1：官方 USDC）───────────────────────
# 設定後，每筆付費訊號真的呼叫【x402 專用】FeeRouter.routeExternalRevenue 走 70/20/10
# （70% 歸該 trader）。此 FeeRouter 綁官方 USDC，與永續引擎的 MockUSDC 分離。
# 流程：x402 付款 → treasury EOA 收官方 USDC → 此金鑰 approve + routeExternalRevenue。
# ⚠ 此金鑰 = treasury EOA（= PAY_TO），需持官方 USDC + 少量 ETH。僅限測試錢包。
FEE_SETTLEMENT_PRIVATE_KEY=
# x402 專用 FeeRouter（已部署並鏈上驗證綁官方 USDC；treasury=PAY_TO）。
X402_FEE_ROUTER=0x29e5732AC62254d9b92A1C7d3F38EbFA8809B57d
# 結算 token（官方 Base Sepolia USDC, 6-dec）。
X402_SETTLEMENT_TOKEN=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ERC-8126 驗證者簽章用金鑰（正式環境務必設，否則每次重啟 verifier DID 會變）
VERIFIER_PRIVATE_KEY=

# 領幣：Base Sepolia ETH（gas）+ 官方測試 USDC（付 x402）。
#   ETH  : https://docs.base.org/chain/network-faucets
#   USDC : https://faucet.circle.com  (選 Base Sepolia) 或 CDP faucet

# ── Signal API server ────────────────────────────────────────────────────────
SIGNAL_API_PORT=4021
SIGNAL_API_URL=http://localhost:4021

# ── Demo agent 錢包（自管 EOA，付 x402 費用用）──────────────────────────────
# 自管 EOA 私鑰，需在 Base Sepolia 持有測試 USDC + 少量 ETH 付 gas。
# Phase 2 會升級為 session key 委派；Phase 1 先用單一 EOA。
# ⚠️ 僅限測試錢包，切勿放入主錢包私鑰。
AGENT_PRIVATE_KEY=0xYOUR_TEST_EOA_PRIVATE_KEY

# demo agent 要分析的 trader（預設用 addresses 的 demo trader；可填任意已註冊地址）
DEMO_TRADER_ADDRESS=
# demo agent 要查的資產
DEMO_ASSET=sBTC

# ── Phase 2 自主下單（write path，經 AgentSessionManager）────────────────────
# AGENT_PRIVATE_KEY 在此同時當作 session key（自管 EOA / 委派金鑰），在 session
# 限額內代下單；永不持有使用者主錢包私鑰。下列三者齊備時，demo agent / MCP
# write tools 才會真的送鏈，否則優雅退化（只讀 + 印出「本來會下的單」）。
#
# AgentSessionManager 位址。Base Sepolia 已部署：填下方位址即可（或留空走 env）。
# 前端 sessionManager.ts 的 84532 已內建同一位址。
SESSION_MANAGER_ADDRESS=0x5Ebcc64C712C5a26119789dCbD0753981dc518E8
# 使用者 createSession 後得到的 session id（demo agent / bot / autotrade 用它下單）
# 注意：session #0 已過期，改用 #6（到期 2027-06-22、單筆≤50/預算1000/槓桿≤5）。
DEMO_SESSION_ID=6
# 每筆下單保證金（USDC，≥ MIN_MARGIN=10），受 session.maxMarginPerTrade 約束
DEMO_MARGIN=10

# ── Track C：Telegram 交易 agent（agent/tg-bot）──────────────────────────────
# 從 BotFather 取得的 bot token
TELEGRAM_BOT_TOKEN=
# （可選）只允許這個 chat id 下單；留空＝不限制（demo 請務必填你自己的 chat id）
TELEGRAM_ALLOWED_CHAT=
# 使用者簽發的授權 VC（W3C VC JSON）路徑；下單前驗簽 + 鏈上 session 交叉比對
# 從前端 /sessions「Issue VC」匯出後存成此檔（預設 ./tg-bot/vc.json，已 gitignore）
AGENT_AUTH_VC_PATH=./tg-bot/vc.json

# ── Track D：x402 自主交易（examples/x402-autotrade.ts）──────────────────────
# 公開付費 API（x402 訊號）。
X402_API_URL=https://agent-git-master-zuemens-projects.vercel.app
# PerpetualExchange 位址（資訊用；下單經 SESSION_MANAGER_ADDRESS）。
PERP_ADDRESS=0xEf75ECA6514cE96B18382E921aC6190a0cF8c072
# （可選）要買 /signals 的 trader 地址；留空＝用付款錢包自己的地址。
TRADER=
# ⚠ 跑 x402-autotrade 的 AGENT_PRIVATE_KEY 錢包必須持「官方 Base Sepolia USDC」
#   （Circle, EIP-3009，到 Circle 測試網水龍頭領）+ 一點 ETH 付 gas。
#   付款用官方 USDC，與平台模擬 USDT 保證金是兩種幣、用途不同。
