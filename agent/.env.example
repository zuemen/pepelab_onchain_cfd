# ─────────────────────────────────────────────────────────────────────────────
# PepeLab Agent — 環境變數範例（Phase 4：全程 Base Sepolia 同鏈）
# 複製成 .env 後填入實際值：  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── 鏈上讀取（Base Sepolia, chainId 84532）──────────────────────────────────
# 合約部署在 Base Sepolia；位址由 frontend/src/contracts/addresses.ts 讀取，
# 此處只需提供一個 Base Sepolia RPC。可用 Alchemy / 官方 / 公共節點。
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# （選用）回退到舊的 Ethereum Sepolia 部署：設 AGENT_CHAIN_ID=11155111 + 此 RPC。
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# AGENT_CHAIN_ID=84532

# ── x402 付費結算（Base Sepolia — 與合約同鏈）────────────────────────────────
# Phase 4 起 x402 USDC 結算與合約讀取**同一條鏈**（Base Sepolia），跨鏈 caveat 已解。
X402_NETWORK=base-sepolia
# facilitator 負責驗證 + 上鏈結算。可用 x402.org 測試 facilitator 或 CDP。
X402_FACILITATOR_URL=https://x402.org/facilitator

# 收款地址 payTo。留空 → 自動帶入 addresses.ts 的 Base Sepolia FeeRouter
# （x402 收入接 FeeRouter 70/20/10 分潤）。**FeeRouter 與 x402 結算同鏈，直接收款。**
PAY_TO=

# ── x402 收入「真上鏈分潤」結算（選用）─────────────────────────────────────
# 設定後，每筆付費訊號會真的呼叫 FeeRouter.routeExternalRevenue 走 70/20/10
# （70% 歸該 trader）。需一個在 Base Sepolia 上、持少量 ETH 的測試金鑰；
# mUSDC 餘額不足時程式會自動 mint（MockUSDC public）。
# 留空 = 停用，僅保留鏈下帳務（/revenue）。⚠ 僅限測試錢包。
FEE_SETTLEMENT_PRIVATE_KEY=

# ── Signal API server ────────────────────────────────────────────────────────
SIGNAL_API_PORT=4021
SIGNAL_API_URL=http://localhost:4021

# ── Demo agent 錢包（自管 EOA，付 x402 費用用）──────────────────────────────
# 自管 EOA 私鑰，需在 Base Sepolia 持有測試 USDC + 少量 ETH 付 gas。
# Phase 2 會升級為 session key 委派；Phase 1 先用單一 EOA。
# ⚠️ 僅限測試錢包，切勿放入主錢包私鑰。
AGENT_PRIVATE_KEY=0xYOUR_TEST_EOA_PRIVATE_KEY

# demo agent 要分析的 trader（預設用 addresses 的 demo trader；可填任意已註冊地址）
DEMO_TRADER_ADDRESS=
# demo agent 要查的資產
DEMO_ASSET=sBTC

# ── Phase 2 自主下單（write path，經 AgentSessionManager）────────────────────
# AGENT_PRIVATE_KEY 在此同時當作 session key（自管 EOA / 委派金鑰），在 session
# 限額內代下單；永不持有使用者主錢包私鑰。下列三者齊備時，demo agent / MCP
# write tools 才會真的送鏈，否則優雅退化（只讀 + 印出「本來會下的單」）。
#
# AgentSessionManager 位址。Base Sepolia 已部署：填下方位址即可（或留空走 env）。
# 前端 sessionManager.ts 的 84532 已內建同一位址。
SESSION_MANAGER_ADDRESS=0x5Ebcc64C712C5a26119789dCbD0753981dc518E8
# 使用者 createSession 後得到的 session id（demo agent 用它下單）
DEMO_SESSION_ID=
# 每筆下單保證金（USDC，≥ MIN_MARGIN=10），受 session.maxMarginPerTrade 約束
DEMO_MARGIN=10
