# ─────────────────────────────────────────────────────────────────────────────
# PepeLab Agent — Phase 1 PoC 環境變數範例
# 複製成 .env 後填入實際值：  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── 鏈上讀取（Ethereum Sepolia, chainId 11155111）────────────────────────────
# 合約部署在 Ethereum Sepolia；位址由 frontend/src/contracts/addresses.ts 讀取，
# 此處只需提供一個 Sepolia RPC。可用 Alchemy / Infura / 公共節點。
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ── x402 付費結算（Base Sepolia）─────────────────────────────────────────────
# x402 用 USDC 在 Base Sepolia 結算（與合約讀取是不同鏈，這是設計如此）。
X402_NETWORK=base-sepolia
# facilitator 負責驗證 + 上鏈結算。可用 x402.org 測試 facilitator 或 CDP。
X402_FACILITATOR_URL=https://x402.org/facilitator

# 收款地址 payTo。預設留空 → 程式自動帶入 addresses.ts 的 Sepolia FeeRouter
# （依專案決策：x402 收入接 FeeRouter 70/20/10 分潤）。
#
# ⚠️ 跨鏈 caveat：FeeRouter 部署在 Ethereum Sepolia，Base Sepolia 上「並未」同址
#    部署。若要在 Base Sepolia 真的收到 USDC，請改成你在 Base Sepolia 控制的地址，
#    或先把 FeeRouter 部署到 Base。Phase 1 demo 預設沿用 FeeRouter 位址以對齊架構。
PAY_TO=

# ── x402 收入「真上鏈分潤」結算（選用）─────────────────────────────────────
# 設定後，每筆付費訊號會真的呼叫 FeeRouter.routeExternalRevenue 走 70/20/10
# （70% 歸該 trader）。需是一個在 FeeRouter 所在鏈（Ethereum Sepolia）上、
# 持有少量 ETH 的測試金鑰；mUSDC 餘額不足時程式會自動 mint（MockUSDC public）。
# 留空 = 停用，僅保留鏈下帳務（/revenue）。⚠ 僅限測試錢包。
FEE_SETTLEMENT_PRIVATE_KEY=

# ── Signal API server ────────────────────────────────────────────────────────
SIGNAL_API_PORT=4021
SIGNAL_API_URL=http://localhost:4021

# ── Demo agent 錢包（自管 EOA，付 x402 費用用）──────────────────────────────
# 自管 EOA 私鑰，需在 Base Sepolia 持有測試 USDC + 少量 ETH 付 gas。
# Phase 2 會升級為 session key 委派；Phase 1 先用單一 EOA。
# ⚠️ 僅限測試錢包，切勿放入主錢包私鑰。
AGENT_PRIVATE_KEY=0xYOUR_TEST_EOA_PRIVATE_KEY

# demo agent 要分析的 trader（預設用 addresses 的 demo trader；可填任意已註冊地址）
DEMO_TRADER_ADDRESS=
# demo agent 要查的資產
DEMO_ASSET=sBTC
